SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
# Storage bucket for images (must exist in Supabase → Storage)
SUPABASE_STORAGE_BUCKET=archify
# Set to true only if the bucket is public (Dashboard → Storage → archify → Public)
# If false (default), the API returns signed URLs like Supabase "Copy URL"
SUPABASE_STORAGE_PUBLIC=false
# Signed URL lifetime in seconds (default: 7 days)
SUPABASE_SIGNED_URL_EXPIRES=604800
